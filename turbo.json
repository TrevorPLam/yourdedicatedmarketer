{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["~/.env", ".env.local"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "NEXT_PUBLIC_SITE_URL",
    "VERCEL_ENV",
    "CF_PAGES",
    "TURBO_TOKEN",
    "SENTRY_DSN",
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "NEON_URL",
    "GOOGLE_ANALYTICS_ID"
  ],

  "tasks": {
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": ["dist/**", ".next/**", "public/build/**"],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig.json",
        "tailwind.config.*"
      ],
      "cache": true,
      "env": ["NODE_ENV", "NEXT_PUBLIC_SITE_URL"]
    },

    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NODE_ENV",
        "DATABASE_URL",
        "NEXT_PUBLIC_SITE_URL",
        "SUPABASE_URL"
      ]
    },

    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "test/**", "package.json", "vitest.config.*"],
      "cache": true
    },
    "test:coverage": {
      "dependsOn": ["test"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "test/**", "package.json"],
      "cache": true
    },
    "test:watch": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },

    "lint": {
      "outputs": [],
      "inputs": ["src/**", "package.json", "eslint.config.*"],
      "cache": true
    },
    "lint:fix": {
      "outputs": [],
      "inputs": ["src/**", "package.json", "eslint.config.*"],
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**", "types/**", "package.json", "tsconfig.json"],
      "cache": true
    },
    "format": {
      "outputs": [],
      "inputs": ["src/**", "package.json", ".prettierrc"],
      "cache": false
    },
    "format:check": {
      "outputs": [],
      "inputs": ["src/**", "package.json", ".prettierrc"],
      "cache": true
    },

    "db:migrate": {
      "cache": false,
      "outputs": [],
      "inputs": ["packages/database/**", "migrations/**"]
    },
    "db:generate": {
      "outputs": ["packages/types/generated/**"],
      "inputs": ["packages/database/**", "packages/types/**"],
      "cache": true
    },
    "db:seed": {
      "dependsOn": ["db:migrate"],
      "cache": false,
      "outputs": [],
      "inputs": ["packages/database/**", "seeds/**"]
    },
    "db:reset": {
      "cache": false,
      "outputs": []
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },

    "docs:dev": {
      "cache": false,
      "persistent": true
    },
    "docs:build": {
      "dependsOn": ["^build"],
      "outputs": ["docs-dist/**"],
      "inputs": ["docs/**", "package.json"],
      "cache": true
    },

    "storybook": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "storybook:build": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"],
      "inputs": ["src/**", "stories/**", "package.json", ".storybook/**"],
      "cache": true
    },

    "deploy:staging": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["VERCEL_ENV", "VERCEL_TOKEN"]
    },
    "deploy:production": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["VERCEL_ENV", "VERCEL_TOKEN"]
    },
    "deploy:preview": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["VERCEL_ENV", "VERCEL_TOKEN"]
    },

    "clean": {
      "cache": false,
      "outputs": []
    },
    "clean:full": {
      "cache": false,
      "outputs": []
    }
  },

  "remoteCache": {
    "enabled": true
  }
}
