{
  "name": "@agency/analytics",
  "version": "1.0.0",
  "description": "Privacy-compliant analytics tracking with multi-provider support",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./consent": {
      "types": "./dist/consent.d.ts",
      "import": "./dist/consent.js",
      "require": "./dist/consent.js",
      "default": "./dist/consent.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@agency/types": "workspace:*",
    "@agency/design-system": "workspace:*",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0",
    "tsup": "^8.0.0"
  },
  "keywords": [
    "analytics",
    "privacy",
    "gdpr",
    "ccpa",
    "tracking",
    "consent"
  ],
  "author": "Agency Team",
  "license": "MIT"
}
