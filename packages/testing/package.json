{
  "name": "@agency/testing",
  "version": "1.0.0",
  "description": "Shared testing utilities and utilities for the marketing agency monorepo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./astro": {
      "types": "./dist/astro.d.ts",
      "import": "./dist/astro.js",
      "require": "./dist/astro.js",
      "default": "./dist/astro.js"
    },
    "./database": {
      "types": "./dist/database.d.ts",
      "import": "./dist/database.js",
      "require": "./dist/database.js",
      "default": "./dist/database.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.5.0",
    "vitest": "^3.0.0",
    "jsdom": "^26.0.0",
    "msw": "^2.6.0",
    "@faker-js/faker": "^9.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.0",
    "@types/node": "^22.12.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "astro": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "astro": {
      "optional": true
    }
  }
}
