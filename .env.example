# Marketing Agency Monorepo Environment Configuration
# ===================================================
# This file contains all environment variables used across the monorepo
# Copy this file to .env.local and fill in your actual values
# NEVER commit actual .env files to version control

# ===========================================
# CORE INFRASTRUCTURE
# ===========================================
NODE_ENV=development
PNPM_STORE_DIR=~/.pnpm-store
TURBO_TOKEN=your_turbo_token_here

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_PROVIDER=supabase
# Options: supabase | neon | postgres

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Neon Configuration (2026 Best Practices)
NEON_URL=your_neon_database_url
NEON_POOLED_URL=your_neon_pooled_url
NEON_SERVERLESS_URL=postgres://[user]:[password]@[neon-hostname]/[db]?sslmode=require
NEON_API_KEY=your_neon_api_key

# PostgreSQL Native Configuration
POSTGRES_URL=postgresql://user:password@localhost:5432/agency_db
POSTGRES_POOL_URL=postgresql://user:password@localhost:6432/agency_db

# Database Features (2026)
ENABLE_REALTIME=true
ENABLE_VECTOR_SEARCH=true
ENABLE_BRANCHING=true
ENABLE_BACKUP_AUTOMATION=true

# ===========================================
# PLATFORM CONFIGURATION
# ===========================================
# Vercel Configuration
VERCEL_ORG_ID=your_vercel_organization_id
VERCEL_TOKEN=your_vercel_personal_access_token
VERCEL_PROJECT_ID=your_vercel_project_id

# Cloudflare Configuration
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# AWS Configuration (for S3, CloudFront, etc.)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_s3_bucket_name

# ===========================================
# CLIENT CONFIGURATION
# ===========================================
# Client Domains
CLIENT_ALPHA_DOMAIN=alpha-client.com
CLIENT_BETA_DOMAIN=beta-client.com
CLIENT_GAMMA_DOMAIN=gamma-client.com

# Client-specific Environment Variables
CLIENT_ALPHA_SUPABASE_URL=client_alpha_supabase_url
CLIENT_ALPHA_SUPABASE_KEY=client_alpha_supabase_key
CLIENT_BETA_SUPABASE_URL=client_beta_supabase_url
CLIENT_BETA_SUPABASE_KEY=client_beta_supabase_key

# ===========================================
# MONITORING & ANALYTICS
# ===========================================
# Sentry Configuration
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# Google Analytics
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
GOOGLE_TAG_MANAGER_ID=GTM_CONTAINER_ID
GOOGLE_SEARCH_CONSOLE_VERIFICATION=your_verification_code

# Vercel Analytics
VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# ===========================================
# DEVELOPMENT TOOLS
# ===========================================
# Local Development URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_AGENCY_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Environment Flags
VERCEL_ENV=development
CF_PAGES=0
IS_DEVELOPMENT=true
IS_PREVIEW=false
IS_PRODUCTION=false

# ===========================================
# SECURITY & COMPLIANCE
# ===========================================
# Authentication & Encryption
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
ENCRYPTION_KEY=your_32_character_encryption_key_here
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# API Security
API_RATE_LIMIT=100
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Content Security Policy
CSP_NONCE=random_nonce_value
FRAME_ANCESTORS=self

# ===========================================
# FEATURE FLAGS
# ===========================================
# Feature Toggles
ENABLE_ANALYTICS=true
ENABLE_ERROR_TRACKING=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_DEBUG_MODE=false
ENABLE_STORYBOOK=true
ENABLE_HOT_RELOAD=true
ENABLE_LOGGING=true

# Database Features
ENABLE_DATABASE_LOGGING=false
ENABLE_QUERY_CACHE=true
ENABLE_CONNECTION_POOLING=true

# Content Management
ENABLE_CMS_PREVIEW=true
ENABLE_DRAFT_MODE=true
ENABLE_LIVE_RELOAD=true

# ===========================================
# EMAIL & COMMUNICATION
# ===========================================
# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@youragency.com
SENDGRID_FROM_NAME=Your Agency Name

# Resend Configuration (2026 Alternative)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@youragency.com

# SMTP Configuration (Alternative)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ===========================================
# THIRD-PARTY INTEGRATIONS
# ===========================================
# Contentful CMS
CONTENTFUL_SPACE_ID=your_contentful_space_id
CONTENTFUL_ACCESS_TOKEN=your_contentful_access_token
CONTENTFUL_PREVIEW_ACCESS_TOKEN=your_contentful_preview_token

# Sanity CMS
SANITY_PROJECT_ID=your_sanity_project_id
SANITY_DATASET=production
SANITY_API_READ_TOKEN=your_sanity_read_token

# Strapi CMS
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your_strapi_api_token

# Stripe Payment Processing
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===========================================
# SEARCH & INDEXING
# ===========================================
# Algolia Search
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_ADMIN_API_KEY=your_algolia_admin_api_key
ALGOLIA_SEARCH_API_KEY=your_algolia_search_api_key

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elasticsearch_password

# ===========================================
# PERFORMANCE & OPTIMIZATION
# ===========================================
# Image Optimization
NEXT_PUBLIC_IMAGE_DOMAINS=yourdomain.com,cdn.yourdomain.com
IMAGE_CDN_URL=https://cdn.yourdomain.com
IMAGE_OPTIMIZATION_QUALITY=80

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_AGE=86400
ENABLE_SWR=true

# Bundle Analysis
BUNDLE_ANALYZE=false
ENABLE_SOURCE_MAPS=false

# ===========================================
# DEVELOPMENT SERVICES
# ===========================================
# Redis (for caching/sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# MinIO (S3-compatible local storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_NAME=agency-storage

# Mailhog (local email testing)
MAILHOG_URL=http://localhost:1025

# ===========================================
# TESTING & QUALITY ASSURANCE
# ===========================================
# Testing Configuration
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/agency_test
ENABLE_TEST_LOGGING=true
TEST_TIMEOUT=30000

# Playwright Configuration
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000
PLAYWRIGHT_HEADED=false
PLAYWRIGHT_SLOWMO=0

# ===========================================
# LOGGING & DEBUGGING
# ===========================================
# Log Levels
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_STRUCTURED_LOGGING=true

# Debug Configuration
DEBUG_MODE=false
VERBOSE_LOGGING=false
ENABLE_REQUEST_LOGGING=false

# ===========================================
# AI & MACHINE LEARNING
# ===========================================
# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_ORG_ID=your_openai_org_id

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key

# ===========================================
# CLIENT-SPECIFIC VARIABLES
# ===========================================
# Client Alpha
CLIENT_ALPHA_NAME=Alpha Corporation
CLIENT_ALPHA_THEME=alpha-brand
CLIENT_ALPHA_PRIMARY_COLOR=#3b82f6
CLIENT_ALPHA_LOGO_URL=https://cdn.client-alpha.com/logo.png

# Client Beta
CLIENT_BETA_NAME=Beta Industries
CLIENT_BETA_THEME=beta-brand
CLIENT_BETA_PRIMARY_COLOR=#10b981
CLIENT_BETA_LOGO_URL=https://cdn.client-beta.com/logo.png

# ===========================================
# DEPLOYMENT & CI/CD
# ===========================================
# GitHub Actions
GITHUB_TOKEN=your_github_token
GITHUB_REPO=your-org/marketing-agency-monorepo
GITHUB_OWNER=your-org

# Docker Configuration
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_TAG=latest
ENABLE_DOCKER_BUILD=true

# ===========================================
# LOCAL DEVELOPMENT OVERRIDES
# ===========================================
# These variables override production settings in development
# Uncomment and modify as needed

# DATABASE_URL=postgresql://dev:dev123@localhost:5432/agency_dev
# REDIS_URL=redis://localhost:6379/0
# ENABLE_DEBUG_MODE=true
# LOG_LEVEL=debug

# ===========================================
# SECURITY NOTES
# ===========================================
# 1. Never commit this file with actual values to version control
# 2. Use strong, unique secrets for production
# 3. Rotate secrets regularly (every 90 days recommended)
# 4. Use environment-specific .env files (.env.development, .env.production)
# 5. Store sensitive values in secret management services in production
# 6. Use different keys for different environments
# 7. Enable security headers and CSP in production
# 8. Monitor for secret leaks and unauthorized access

# ===========================================
# DEVELOPMENT QUICK START
# ===========================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in required values for your environment
# 3. Run: pnpm install
# 4. Run: pnpm dev:setup
# 5. Start development: pnpm dev
