---
interface Props {
	projects: any[];
}

const { projects } = Astro.props;
---

<section class="py-20 bg-gray-50">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-16">
			<h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
				Recent Projects
			</h2>
			<p class="text-xl text-gray-600 max-w-3xl mx-auto">
				Discover how we've helped businesses like yours achieve their digital marketing goals.
			</p>
		</div>
		
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			{projects.map((project: any) => (
				<div class="card hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
					<div class="aspect-w-16 aspect-h-9 bg-gray-200 rounded-t-lg overflow-hidden">
						<img 
							src={project.data.imageUrl || '/images/placeholder-project.jpg'} 
							alt={project.data.imageAlt || `${project.data.title} project`}
							class="w-full h-48 object-cover"
							loading="lazy"
						/>
					</div>
					
					<div class="p-6">
						<div class="flex items-center justify-between mb-2">
							<span class="text-sm text-blue-600 font-medium">
								{project.data.client}
							</span>
							<span class="text-sm text-gray-500">
								{project.data.industry}
							</span>
						</div>
						
						<h3 class="text-xl font-semibold text-gray-900 mb-3">
							{project.data.title}
						</h3>
						
						<p class="text-gray-600 mb-4 line-clamp-3">
							{project.data.description}
						</p>
						
						<div class="flex flex-wrap gap-2 mb-4">
							{project.data.technologies.slice(0, 3).map((tech: string) => (
								<span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">
									{tech}
								</span>
							))}
							{project.data.technologies.length > 3 && (
								<span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">
									+{project.data.technologies.length - 3}
								</span>
							)}
						</div>
						
						<div class="flex space-x-3">
							{project.data.liveUrl && (
								<a 
									href={project.data.liveUrl} 
									class="text-blue-600 hover:text-blue-700 text-sm font-medium"
									target="_blank"
									rel="noopener noreferrer"
								>
									View Live →
								</a>
							)}
							{project.data.githubUrl && (
								<a 
									href={project.data.githubUrl} 
									class="text-gray-600 hover:text-gray-700 text-sm font-medium"
									target="_blank"
									rel="noopener noreferrer"
								>
									GitHub →
								</a>
							)}
						</div>
					</div>
				</div>
			))}
		</div>
		
		<div class="text-center mt-12">
			<a 
				href="/portfolio" 
				class="btn btn-primary px-8 py-3 text-lg font-semibold"
			>
				View All Projects
			</a>
		</div>
	</div>
</section>
