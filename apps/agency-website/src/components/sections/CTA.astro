<section class="py-20 bg-gradient-to-r from-blue-600 to-indigo-700 text-white">
	<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
		<h2 class="text-3xl sm:text-4xl font-bold mb-6">
			Ready to Grow Your Business?
		</h2>
		
		<p class="text-xl mb-8 text-blue-100 max-w-2xl mx-auto">
			Let's discuss how our digital marketing expertise can help you achieve your business goals. Get a free consultation today.
		</p>
		
		<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
			<a 
				href="/contact" 
				class="btn bg-white text-blue-600 hover:bg-gray-100 px-8 py-4 text-lg font-semibold shadow-lg hover:shadow-xl transition-shadow"
			>
				Get Free Consultation
			</a>
			
			<a 
				href="tel:+1234567890" 
				class="text-white hover:text-blue-100 text-lg font-medium underline underline-offset-4"
			>
				Call (123) 456-7890
			</a>
		</div>
		
		<div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
			<div>
				<div class="text-3xl font-bold mb-2">24h</div>
				<div class="text-blue-100">Response Time</div>
			</div>
			<div>
				<div class="text-3xl font-bold mb-2">Free</div>
				<div class="text-blue-100">Initial Consultation</div>
			</div>
			<div>
				<div class="text-3xl font-bold mb-2">30 Days</div>
				<div class="text-blue-100">Support Guarantee</div>
			</div>
		</div>
	</div>
</section>
