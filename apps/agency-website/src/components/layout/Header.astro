---
import { SITE_CONFIG } from '../../site.config.js';
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center h-16">
			<!-- Logo -->
			<div class="flex-shrink-0">
				<a 
					href="/" 
					class="flex items-center space-x-3 text-xl font-bold text-gray-900 hover:text-blue-600 transition-colors"
					aria-label={`${SITE_CONFIG.title} homepage`}
					data-testid="nav-home"
				>
					<svg 
						class="w-8 h-8" 
						fill="currentColor" 
						viewBox="0 0 24 24" 
						aria-hidden="true"
					>
						<path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/>
					</svg>
					<span class="hidden sm:inline">Your Agency</span>
				</a>
			</div>
			
			<!-- Desktop Navigation -->
			<nav class="hidden md:flex space-x-8" aria-label="Main navigation" data-testid="navigation">
				<a 
					href="/services" 
					class="text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium transition-colors"
					data-testid="nav-services"
				>
					Services
				</a>
				<a 
					href="/portfolio" 
					class="text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium transition-colors"
					data-testid="nav-portfolio"
				>
					Portfolio
				</a>
				<a 
					href="/about" 
					class="text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium transition-colors"
				>
					About
				</a>
				<a 
					href="/blog" 
					class="text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium transition-colors"
				>
					Blog
				</a>
				<a 
					href="/contact" 
					class="bg-blue-600 text-white hover:bg-blue-700 px-4 py-2 rounded-md text-sm font-medium transition-colors"
				>
					Get Started
				</a>
			</nav>
			
			<!-- Mobile menu button -->
			<div class="md:hidden">
				<button
					type="button"
					class="text-gray-600 hover:text-gray-900 p-2 rounded-md"
					aria-label="Open mobile menu"
					aria-expanded="false"
					data-mobile-menu-toggle
					data-testid="mobile-menu-button"
				>
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
					</svg>
				</button>
			</div>
		</div>
		
		<!-- Mobile Navigation -->
		<nav 
			class="md:hidden hidden" 
			aria-label="Mobile navigation"
			data-mobile-menu
			data-testid="mobile-menu"
		>
			<div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
				<a 
					href="/services" 
					class="text-gray-600 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium"
					data-testid="mobile-nav-services"
				>
					Services
				</a>
				<a 
					href="/portfolio" 
					class="text-gray-600 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium"
				>
					Portfolio
				</a>
				<a 
					href="/about" 
					class="text-gray-600 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium"
				>
					About
				</a>
				<a 
					href="/blog" 
					class="text-gray-600 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium"
				>
					Blog
				</a>
				<a 
					href="/contact" 
					class="bg-blue-600 text-white block px-3 py-2 rounded-md text-base font-medium"
				>
					Get Started
				</a>
			</div>
		</nav>
	</div>
</header>

<script>
	// Mobile menu toggle
	document.addEventListener('DOMContentLoaded', () => {
		const toggle = document.querySelector('[data-mobile-menu-toggle]');
		const menu = document.querySelector('[data-mobile-menu]');
		
		if (toggle && menu) {
			toggle.addEventListener('click', () => {
				const isHidden = menu.classList.contains('hidden');
				
				if (isHidden) {
					menu.classList.remove('hidden');
					toggle.setAttribute('aria-expanded', 'true');
				} else {
					menu.classList.add('hidden');
					toggle.setAttribute('aria-expanded', 'false');
				}
			});
			
			// Close menu when clicking outside
			document.addEventListener('click', (e) => {
				const target = e.target as Element;
				if (menu && !menu.contains(target) && toggle && !toggle.contains(target)) {
					menu.classList.add('hidden');
					toggle.setAttribute('aria-expanded', 'false');
				}
			});
		}
	});
</script>
