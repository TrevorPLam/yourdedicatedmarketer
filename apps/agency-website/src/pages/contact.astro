---
import Base from '../layouts/Base.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { SITE_CONFIG } from '../site.config.js';
---

<Base title="Contact Us - Your Dedicated Marketer" description="Get in touch with Your Dedicated Marketer. We'd love to learn about your business and how we can help you grow.">
	<div class="min-h-screen flex flex-col">
		<Header />

		<main id="main-content" class="flex-1">
			<!-- Page Header -->
			<section class="bg-gradient-to-br from-blue-50 to-indigo-100 py-16">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
					<h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6">
						Get In Touch
					</h1>
					<p class="text-xl text-gray-600 max-w-3xl mx-auto">
						Ready to grow your business? We'd love to hear about your goals and show you how we can help.
					</p>
				</div>
			</section>

			<!-- Contact Section -->
			<section class="py-20 bg-white">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
						<!-- Contact Info -->
						<div>
							<h2 class="text-2xl font-bold text-gray-900 mb-8">Let's Start a Conversation</h2>

							<div class="space-y-6">
								<div class="flex items-start space-x-4">
									<div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
										<svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
										</svg>
									</div>
									<div>
										<h3 class="font-semibold text-gray-900 mb-1">Email Us</h3>
										<a href="mailto:hello@yourdedicatedmarketer.com" class="text-blue-600 hover:underline">
											hello@yourdedicatedmarketer.com
										</a>
										<p class="text-gray-500 text-sm mt-1">We respond within 24 hours.</p>
									</div>
								</div>

								<div class="flex items-start space-x-4">
									<div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
										<svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
										</svg>
									</div>
									<div>
										<h3 class="font-semibold text-gray-900 mb-1">Call Us</h3>
										<a href="tel:+12345678 90" class="text-blue-600 hover:underline">
											(123) 456-7890
										</a>
										<p class="text-gray-500 text-sm mt-1">Mon–Fri, 9am–6pm EST</p>
									</div>
								</div>

								<div class="flex items-start space-x-4">
									<div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
										<svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
										</svg>
									</div>
									<div>
										<h3 class="font-semibold text-gray-900 mb-1">Free Consultation</h3>
										<p class="text-gray-600">Your first strategy session is on us — no obligations.</p>
									</div>
								</div>
							</div>

							<div class="mt-12 p-6 bg-blue-50 rounded-xl">
								<h3 class="font-semibold text-gray-900 mb-3">What to Expect</h3>
								<ul class="space-y-2 text-gray-600 text-sm">
									<li class="flex items-center space-x-2">
										<svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
										</svg>
										<span>We'll review your current marketing and website within 24 hours</span>
									</li>
									<li class="flex items-center space-x-2">
										<svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
										</svg>
										<span>A 30-minute discovery call to understand your goals</span>
									</li>
									<li class="flex items-center space-x-2">
										<svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
										</svg>
										<span>A clear, actionable proposal — no fluff, no pressure</span>
									</li>
								</ul>
							</div>
						</div>

						<!-- Contact Form -->
						<div>
							<h2 class="text-2xl font-bold text-gray-900 mb-8">Send Us a Message</h2>
							<form
								method="POST"
								action="/api/contact"
								class="space-y-6"
								novalidate
							>
								<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
									<div>
										<label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">
											First Name <span class="text-red-500" aria-hidden="true">*</span>
										</label>
										<input
											type="text"
											id="firstName"
											name="firstName"
											required
											autocomplete="given-name"
											class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors"
											placeholder="Jane"
										/>
									</div>
									<div>
										<label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">
											Last Name <span class="text-red-500" aria-hidden="true">*</span>
										</label>
										<input
											type="text"
											id="lastName"
											name="lastName"
											required
											autocomplete="family-name"
											class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors"
											placeholder="Smith"
										/>
									</div>
								</div>

								<div>
									<label for="email" class="block text-sm font-medium text-gray-700 mb-2">
										Email Address <span class="text-red-500" aria-hidden="true">*</span>
									</label>
									<input
										type="email"
										id="email"
										name="email"
										required
										autocomplete="email"
										class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors"
										placeholder="jane@yourbusiness.com"
									/>
								</div>

								<div>
									<label for="company" class="block text-sm font-medium text-gray-700 mb-2">
										Company Name
									</label>
									<input
										type="text"
										id="company"
										name="company"
										autocomplete="organization"
										class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors"
										placeholder="Your Business LLC"
									/>
								</div>

								<div>
									<label for="service" class="block text-sm font-medium text-gray-700 mb-2">
										Service Interested In
									</label>
									<select
										id="service"
										name="service"
										class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors bg-white"
									>
										<option value="">Select a service...</option>
										<option value="web-design">Web Design &amp; Development</option>
										<option value="seo">SEO Optimization</option>
										<option value="content-marketing">Content Marketing</option>
										<option value="social-media">Social Media Management</option>
										<option value="email-marketing">Email Marketing</option>
										<option value="analytics">Analytics &amp; Reporting</option>
										<option value="other">Other / Not Sure Yet</option>
									</select>
								</div>

								<div>
									<label for="message" class="block text-sm font-medium text-gray-700 mb-2">
										Tell Us About Your Project <span class="text-red-500" aria-hidden="true">*</span>
									</label>
									<textarea
										id="message"
										name="message"
										required
										rows={5}
										class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors resize-y"
										placeholder="Share your goals, current challenges, or anything else you'd like us to know..."
									></textarea>
								</div>

								<button
									type="submit"
									class="w-full btn btn-primary py-4 text-lg font-semibold shadow-md hover:shadow-lg transition-shadow"
								>
									Send Message
								</button>

								<p class="text-xs text-gray-500 text-center">
									By submitting this form, you agree to our <a href="/privacy" class="underline hover:text-gray-700">Privacy Policy</a>. We never share your information.
								</p>
							</form>
						</div>
					</div>
				</div>
			</section>
		</main>

		<Footer />
	</div>
</Base>
