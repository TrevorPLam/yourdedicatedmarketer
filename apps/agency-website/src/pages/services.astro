---
import Base from '../layouts/Base.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CTA from '../components/sections/CTA.astro';
import { getCollection } from 'astro:content';

const allServices = await getCollection('services');
allServices.sort((a, b) => a.data.title.localeCompare(b.data.title));

const serviceIcons: Record<string, string> = {
	palette: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>`,
	search: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>`,
	chart: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>`,
	megaphone: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path>`,
	mail: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>`,
};

const defaultIcon = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>`;
---

<Base title="Our Services - Your Dedicated Marketer" description="Comprehensive digital marketing services including web design, SEO, content marketing, social media, and more.">
	<div class="min-h-screen flex flex-col">
		<Header />

		<main id="main-content" class="flex-1">
			<!-- Page Header -->
			<section class="bg-gradient-to-br from-blue-50 to-indigo-100 py-16">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
					<h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6">
						Our Services
					</h1>
					<p class="text-xl text-gray-600 max-w-3xl mx-auto">
						We offer comprehensive digital marketing services designed to help your business grow, stand out, and convert visitors into loyal customers.
					</p>
				</div>
			</section>

			<!-- Services Grid -->
			<section class="py-20 bg-white">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					{allServices.length > 0 ? (
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
							{allServices.map((service) => (
								<div class="card hover:shadow-lg transition-shadow duration-300">
									<div class="p-8">
										<div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-6">
											<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<Fragment set:html={serviceIcons[service.data.icon ?? ''] ?? defaultIcon} />
											</svg>
										</div>

										<h2 class="text-xl font-semibold text-gray-900 mb-4">
											{service.data.title}
										</h2>

										<p class="text-gray-600 mb-6">
											{service.data.description}
										</p>

										<div class="space-y-3">
											{service.data.price && (
												<div class="text-lg font-semibold text-blue-600">
													{service.data.price}
												</div>
											)}
											{service.data.duration && (
												<div class="text-sm text-gray-500">
													Timeline: {service.data.duration}
												</div>
											)}
											{service.data.tags.length > 0 && (
												<div class="flex flex-wrap gap-2 pt-2">
													{service.data.tags.map((tag) => (
														<span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">
															{tag}
														</span>
													))}
												</div>
											)}
										</div>
									</div>
								</div>
							))}
						</div>
					) : (
						<div class="text-center py-16">
							<p class="text-xl text-gray-500">Service details coming soon. <a href="/contact" class="text-blue-600 hover:underline">Contact us</a> to learn more.</p>
						</div>
					)}
				</div>
			</section>

			<!-- Why Choose Us -->
			<section class="py-20 bg-gray-50">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					<div class="text-center mb-16">
						<h2 class="text-3xl font-bold text-gray-900 mb-4">Why Choose Us?</h2>
						<p class="text-xl text-gray-600 max-w-2xl mx-auto">
							We combine strategy, creativity, and data to deliver measurable results for your business.
						</p>
					</div>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						<div class="text-center p-8 bg-white rounded-xl shadow-sm">
							<div class="text-4xl font-bold text-blue-600 mb-3">150+</div>
							<div class="text-lg font-semibold text-gray-900 mb-2">Happy Clients</div>
							<p class="text-gray-600">Businesses across industries trust us to manage their digital presence.</p>
						</div>
						<div class="text-center p-8 bg-white rounded-xl shadow-sm">
							<div class="text-4xl font-bold text-blue-600 mb-3">500+</div>
							<div class="text-lg font-semibold text-gray-900 mb-2">Projects Delivered</div>
							<p class="text-gray-600">From landing pages to full-scale web applications, we've done it all.</p>
						</div>
						<div class="text-center p-8 bg-white rounded-xl shadow-sm">
							<div class="text-4xl font-bold text-blue-600 mb-3">98%</div>
							<div class="text-lg font-semibold text-gray-900 mb-2">Satisfaction Rate</div>
							<p class="text-gray-600">Our clients stay because we consistently deliver on our promises.</p>
						</div>
					</div>
				</div>
			</section>

			<CTA />
		</main>

		<Footer />
	</div>
</Base>
