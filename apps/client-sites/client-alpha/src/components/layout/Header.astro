---
import { CLIENT_CONFIG, I18N_CONFIG } from '../site.config.js';
import { Button } from '@agency/ui-components/react';
import { useState } from 'react';

const { navigation } = I18N_CONFIG.messages[I18N_CONFIG.defaultLocale];

export interface Props {
	locale?: string;
}

const { locale = I18N_CONFIG.defaultLocale } = Astro.props;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200">
	<nav class="container mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center h-16">
			<!-- Logo -->
			<div class="flex-shrink-0">
				<a href="/" class="flex items-center space-x-2">
					<img 
						src={CLIENT_CONFIG.branding.logo} 
						alt={CLIENT_CONFIG.name}
						class="h-8 w-auto"
						width="32"
						height="32"
					/>
					<span class="text-xl font-bold text-gray-900">
						{CLIENT_CONFIG.name}
					</span>
				</a>
			</div>

			<!-- Desktop Navigation -->
			<div class="hidden md:flex items-center space-x-8">
				{Object.entries(navigation).map(([key, value]) => (
					<a
						href={`/${key === 'home' ? '' : key}`}
						class="text-gray-600 hover:text-brand-600 transition-colors font-medium"
					>
						{value}
					</a>
				))}
			</div>

			<!-- CTA Button -->
			<div class="hidden md:block">
				<Button client:load variant="primary" size="sm">
					Get Started
				</Button>
			</div>

			<!-- Mobile Menu Button -->
			<div class="md:hidden">
				<button
					type="button"
					class="text-gray-600 hover:text-brand-600 p-2"
					aria-label="Open mobile menu"
					onclick="toggleMobileMenu()"
				>
					<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
					</svg>
				</button>
			</div>
		</div>

		<!-- Mobile Navigation -->
		<div id="mobile-menu" class="hidden md:hidden">
			<div class="px-2 pt-2 pb-3 space-y-1 bg-white border-t border-gray-200">
				{Object.entries(navigation).map(([key, value]) => (
					<a
						href={`/${key === 'home' ? '' : key}`}
						class="block px-3 py-2 text-gray-600 hover:text-brand-600 hover:bg-gray-50 rounded-md font-medium"
					>
						{value}
					</a>
				))}
				<div class="px-3 py-2">
					<Button client:load variant="primary" size="sm" class="w-full">
						Get Started
					</Button>
				</div>
			</div>
		</div>
	</nav>
</header>

<script>
	function toggleMobileMenu() {
		const menu = document.getElementById('mobile-menu');
		menu.classList.toggle('hidden');
	}
</script>
