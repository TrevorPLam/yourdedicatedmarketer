---
import { Card } from '@agency/ui-components/react';
---

<section class="py-20 bg-gray-50">
	<div class="container mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-16">
			<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
				What Our Clients Say
			</h2>
			<p class="text-xl text-gray-600 max-w-3xl mx-auto">
				Don't just take our word for it - hear from our satisfied clients
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			<Card className="p-8">
				<div class="flex items-center mb-4">
					<div class="w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center mr-4">
						<span class="text-brand-600 font-semibold text-lg">JD</span>
					</div>
					<div>
						<h4 class="font-semibold text-gray-900">John Doe</h4>
						<p class="text-sm text-gray-600">CEO, TechCorp</p>
					</div>
				</div>
				<div class="flex mb-4">
					{[1, 2, 3, 4, 5].map((star) => (
						<svg key={star} class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
							<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
						</svg>
					))}
				</div>
				<p class="text-gray-600 italic">
					"Exceptional service and outstanding results. They transformed our digital presence and helped us achieve our business goals."
				</p>
			</Card>

			<Card className="p-8">
				<div class="flex items-center mb-4">
					<div class="w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center mr-4">
						<span class="text-brand-600 font-semibold text-lg">SM</span>
					</div>
					<div>
						<h4 class="font-semibold text-gray-900">Sarah Miller</h4>
						<p class="text-sm text-gray-600">Marketing Director, StartupXYZ</p>
					</div>
				</div>
				<div class="flex mb-4">
					{[1, 2, 3, 4, 5].map((star) => (
						<svg key={star} class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
							<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
						</svg>
					))}
				</div>
				<p class="text-gray-600 italic">
					"Professional team with deep expertise. They delivered our project on time and exceeded our expectations."
				</p>
			</Card>

			<Card className="p-8">
				<div class="flex items-center mb-4">
					<div class="w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center mr-4">
						<span class="text-brand-600 font-semibold text-lg">MJ</span>
					</div>
					<div>
						<h4 class="font-semibold text-gray-900">Michael Johnson</h4>
						<p class="text-sm text-gray-600">CTO, InnovateCo</p>
					</div>
				</div>
				<div class="flex mb-4">
					{[1, 2, 3, 4, 5].map((star) => (
						<svg key={star} class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
							<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
						</svg>
					))}
				</div>
				<p class="text-gray-600 italic">
					"Innovative solutions and excellent support. They helped us scale our platform and improve user experience significantly."
				</p>
			</Card>
		</div>
	</div>
</section>
