---
import { CLIENT_CONFIG, I18N_CONFIG } from '../../site.config.js';
import { Button } from '@agency/ui-components/react';

const { common } = I18N_CONFIG.messages[I18N_CONFIG.defaultLocale];
---

<section class="relative min-h-screen flex items-center justify-center hero-pattern overflow-hidden">
	<!-- Background with overlay -->
	<div class="absolute inset-0 bg-gradient-to-br from-brand-50 via-white to-brand-100 opacity-90"></div>
	
	<div class="relative container mx-auto px-4 sm:px-6 lg:px-8">
		<div class="max-w-4xl mx-auto text-center">
			<!-- Badge -->
			<div class="inline-flex items-center px-4 py-2 bg-brand-100 text-brand-800 rounded-full text-sm font-medium mb-6 animate-float">
				<svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
					<path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/>
				</svg>
				Trusted by 500+ companies worldwide
			</div>

			<!-- Main Heading -->
			<h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight">
				<span class="block">Transform Your</span>
				<span class="block text-brand-600">Business Today</span>
			</h1>

			<!-- Description -->
			<p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-3xl mx-auto leading-relaxed">
				We help innovative companies build exceptional digital experiences that drive growth, 
				delight customers, and create lasting impact in their industries.
			</p>

			<!-- CTA Buttons -->
			<div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
				<Button client:load variant="primary" size="lg" class="px-8 py-4 text-lg">
					{common.getStarted}
				</Button>
				<Button client:load variant="outline" size="lg" class="px-8 py-4 text-lg border-brand-600 text-brand-600 hover:bg-brand-600 hover:text-white">
					{common.learnMore}
				</Button>
			</div>

			<!-- Trust Indicators -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-2xl mx-auto">
				<div class="text-center">
					<div class="text-3xl font-bold text-brand-600 mb-2">500+</div>
					<div class="text-sm text-gray-600">Happy Clients</div>
				</div>
				<div class="text-center">
					<div class="text-3xl font-bold text-brand-600 mb-2">1,200+</div>
					<div class="text-sm text-gray-600">Projects Completed</div>
				</div>
				<div class="text-center">
					<div class="text-3xl font-bold text-brand-600 mb-2">15+</div>
					<div class="text-sm text-gray-600">Years Experience</div>
				</div>
				<div class="text-center">
					<div class="text-3xl font-bold text-brand-600 mb-2">24/7</div>
					<div class="text-sm text-gray-600">Support</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Decorative Elements -->
	<div class="absolute top-20 left-10 w-20 h-20 bg-brand-200 rounded-full opacity-50 animate-bounce-soft"></div>
	<div class="absolute bottom-20 right-10 w-32 h-32 bg-brand-300 rounded-full opacity-30 animate-bounce-soft" style="animation-delay: 1s;"></div>
	<div class="absolute top-1/2 right-1/4 w-16 h-16 bg-brand-100 rounded-full opacity-40 animate-bounce-soft" style="animation-delay: 2s;"></div>
</section>
