{
  "name": "marketing-agency-monorepo",
  "version": "2.0.0",
  "description": "Enterprise-grade monorepo for marketing agency operations",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "# Development Commands": "=== Development Commands ===",
    "dev": "turbo run dev --parallel",
    "dev:setup": "pnpm install && turbo run db:migrate && turbo run db:seed && turbo run dev",
    "dev:client": "turbo gen client-site",
    "# Build Commands": "=== Build Commands ===",
    "build": "turbo run build",
    "build:affected": "turbo run build --filter=!@agency/docs",
    "build:production": "NODE_ENV=production turbo run build",
    "build:client": "turbo run build --filter=$CLIENT_NAME",
    "# Testing Commands": "=== Testing Commands ===",
    "test": "turbo run test",
    "test:e2e": "exec playwright test",
    "test:e2e:ui": "exec playwright test --ui",
    "test:e2e:debug": "exec playwright test --debug",
    "test:coverage": "turbo run test:coverage -- --coverage.reporter=html",
    "test:affected": "turbo run test --filter=!@agency/docs",
    "test:watch": "turbo run test --watch",
    "test:ui": "vitest --ui",
    "test:build": "turbo run build && turbo run test",
    "# Code Quality Commands": "=== Code Quality Commands ===",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint --fix",
    "lint:all": "turbo run lint --all",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "prepare": "husky",
    "# Database Commands": "=== Database Commands ===",
    "db:migrate": "turbo run db:migrate",
    "db:generate": "turbo run db:generate",
    "db:seed": "turbo run db:seed",
    "db:reset": "turbo run db:reset",
    "db:studio": "turbo run db:studio",
    "# Deployment Commands": "=== Deployment Commands ===",
    "deploy:staging": "turbo run deploy:staging",
    "deploy:production": "turbo run deploy:production",
    "deploy:client": "node tools/scripts/deploy-client.js",
    "deploy:preview": "turbo run deploy:preview",
    "# Package Management Commands": "=== Package Management Commands ===",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=!@agency/docs && changeset publish",
    "clean": "turbo run clean && node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('node_modules', { recursive: true, force: true });\"",
    "clean:full": "pnpm clean && node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('.turbo', { recursive: true, force: true });\"",
    "# Generator Commands": "=== Generator Commands ===",
    "new:client": "turbo gen client-site",
    "new:component": "turbo gen component",
    "new:package": "node tools/generators/create-package.js",
    "new:service": "node tools/generators/create-service.js",
    "# Documentation Commands": "=== Documentation Commands ===",
    "docs:dev": "turbo run docs:dev",
    "docs:build": "turbo run docs:build",
    "docs:generate": "cd docs && pnpm run generate-api",
    "docs:sync": "cd docs && pnpm run sync-components",
    "storybook": "turbo run storybook",
    "storybook:build": "turbo run storybook:build",
    "# Governance Commands": "=== Governance Commands ===",
    "governance:check": "node tools/governance/policy-checker.js",
    "governance:check:deps": "node tools/governance/policy-checker.js --check-dependencies",
    "governance:check:ownership": "node tools/governance/policy-checker.js --check-ownership",
    "governance:check:security": "node tools/governance/policy-checker.js --check-security",
    "governance:fix": "node tools/governance/policy-checker.js --fix",
    "governance:boundaries": "node tools/governance/boundary-enforcer.js",
    "governance:boundaries:graph": "node tools/governance/boundary-enforcer.js --graph",
    "governance:boundaries:circular": "node tools/governance/boundary-enforcer.js --check-circular",
    "governance:boundaries:score": "node tools/governance/boundary-enforcer.js --score",
    "governance:imports": "node tools/governance/import-export-audit.mjs",
    "governance:validate": "node tools/governance/policy-checker.js && node tools/governance/boundary-enforcer.js && node tools/governance/import-export-audit.mjs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "catalog:",
    "@playwright/test": "^1.59.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.0",
    "@turbo/gen": "^2.3.0",
    "@types/node": "^22.12.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "c8": "^9.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.0",
    "dependency-cruiser": "^17.3.10",
    "dotenv": "^16.4.0",
    "eslint": "^9.23.0",
    "eslint-plugin-astro": "^1.2.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "glob": "^10.3.10",
    "husky": "^9.1.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.4.0",
    "msw": "^2.6.0",
    "nodemon": "^3.1.0",
    "only-allow": "^1.2.2",
    "playwright": "^1.59.0",
    "prettier": "^3.5.0",
    "turbo": "^2.9.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/marketing-agency-monorepo.git"
  },
  "keywords": [
    "monorepo",
    "marketing-agency",
    "astro",
    "nextjs",
    "typescript",
    "turborepo",
    "pnpm",
    "enterprise"
  ],
  "author": "Your Agency Name",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/your-org/marketing-agency-monorepo/issues"
  },
  "homepage": "https://github.com/your-org/marketing-agency-monorepo#readme",
  "dependencies": {
    "@agency/ui-components": "workspace:*",
    "@agency/design-system": "workspace:*",
    "@agency/types": "workspace:*",
    "@agency/analytics": "workspace:*",
    "@agency/auth": "workspace:*",
    "@astrojs/react": "^4.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tanstack/react-query": "^5.62.0",
    "astro": "catalog:",
    "astro-i18n-aut": "^0.7.3",
    "date-fns": "^4.1.0",
    "next": "catalog:",
    "recharts": "^2.12.0"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.global.ts",
    "**/*.setup.ts",
    "**/*.client.ts",
    "src/setup/**",
    "dist/**/*.css",
    "!src/**/*.pure.ts"
  ]
}