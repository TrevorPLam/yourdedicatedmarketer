# pnpm configuration for marketing agency monorepo
# Enforces strict dependency management and workspace best practices

# Performance optimizations
force-concurrent-requests=true
prefer-frozen-lockfile=true

# Strict dependency management
strict-peer-dependencies=false
resolution-mode=highest

# Workspace configuration
link-workspace-packages=true
prefer-workspace-packages=true

# Security and reliability
auto-install-peers=true

# Cache optimization
prefer-frozen-lockfile=true
store-dir=~/.pnpm-store

# Prevent accidental package manager usage
# This works with the preinstall script in package.json
